generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id            String    @id @default(cuid())
  accountId     String    @unique          // Unipile account_id
  name          String    @default("")     // Friendly label
  dsn           String?                    // Optional per-account override
  apiKey        String?                    // Optional per-account override
  status        String    @default("ACTIVE") // ACTIVE | BUSY | COOLDOWN | DISABLED
  lastUsedAt    DateTime?
  requestCount  Int       @default(0)      // rolling counter
  dailyCount    Int       @default(0)      // daily usage counter
  dailyResetAt  DateTime?                  // when to reset dailyCount
  minuteCount   Int       @default(0)      // requests in current minute window
  minuteResetAt DateTime?                  // when the current minute window expires
  cooldownUntil DateTime?                  // null = not in cooldown
  createdAt     DateTime  @default(now())
  tasks         Task[]
}

model Job {
  id             String   @id @default(cuid())
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  totalTasks     Int
  processedCount Int      @default(0)
  successCount   Int      @default(0)
  failedCount    Int      @default(0)
  config         String?  @db.Text // JSON: { jobDescription, customPrompt, scoringRules, customScoringRules, sheetWebAppUrl, aiModel }
  createdAt      DateTime @default(now())
  tasks          Task[]
}

model Task {
  id             String   @id @default(cuid())
  jobId          String
  url            String   @db.Text
  status         String   @default("PENDING") // PENDING, PROCESSING, DONE, FAILED
  result         String?  @db.Text // JSON string (raw Unipile profile data)
  analysisResult String?  @db.Text // JSON string (AI scoring output)
  errorMessage   String?  @db.Text // failure reason
  retryCount     Int      @default(0)
  accountId      String?  // assigned at processing time
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id])

  @@index([jobId])
  @@index([accountId])
}

model CandidateProfile {
  id          String    @id @default(cuid())
  linkedinUrl String    // full LinkedIn URL
  name        String    @default("")
  headline    String    @default("")
  location    String    @default("")
  rawProfile  String?   @db.Text // full Unipile JSON (nullable — cleared on free tier to save space)
  scrapedAt   DateTime  @default(now())

  analyses    AnalysisRecord[]

  @@index([linkedinUrl])
  @@index([scrapedAt])
}

model AnalysisRecord {
  id             String   @id @default(cuid())
  candidateId    String
  linkedinUrl    String   // denormalized for fast queries
  candidateName  String   @default("")

  // Job context — WHY this analysis happened
  jobTitle       String
  jobDescription String   @db.Text
  scoringConfig  String   @db.Text // JSON: rules, custom rules, model, prompt

  // Analysis output with all reasoning
  analysisData   String   @db.Text // full AnalysisResult JSON

  // Denormalized for sorting/filtering/dashboards
  totalScore     Int
  maxScore       Int
  scorePercent   Float
  recommendation String   // "Strong Fit" / "Moderate Fit" / "Not a Fit"

  analyzedAt     DateTime @default(now())

  candidate      CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([linkedinUrl])
  @@index([analyzedAt])
  @@index([scorePercent])
  @@index([candidateId])
}

model JdTemplate {
  id                       String   @id @default(cuid())
  title                    String
  content                  String   @db.Text
  scoringRules             String   @db.Text   // JSON: {"stability":true,"growth":false,...}
  customScoringRules       String   @db.Text   // JSON: [{id,name,maxPoints,criteria,enabled}]
  builtInRuleDescriptions  String   @db.Text   @default("{}") // JSON: {"growth":"...","mba":"..."}
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model PromptTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationConfig {
  id                   String   @id @default(cuid())
  title                String
  isDefault            Boolean  @default(false)
  promptRole           String?  @db.Text
  criticalInstructions String?  @db.Text
  promptGuidelines     String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AppSettings {
  id                    String   @id @default("global")
  aiModel               String   @default("gpt-4.1")
  aiProviderId          String?  // FK to AiProvider — the default provider
  sheetWebAppUrl        String   @default("")
  minScoreThreshold     Int      @default(0)
  promptRole            String?  @db.Text // Custom AI evaluator identity — null = default
  promptGuidelines      String?  @db.Text // Custom evaluation guidelines — null = default
  criticalInstructions  String?  @db.Text // Custom behavioral rules — null = default
  updatedAt             DateTime @updatedAt
}

model AiProvider {
  id        String   @id @default(cuid())
  name      String           // User-friendly label, e.g. "My Gemini"
  provider  String           // "openai-compatible" | "anthropic" | "bedrock"
  baseUrl   String           // API base URL — for Bedrock: AWS region (e.g. "us-east-1")
  apiKey    String           // API key — for Bedrock: AWS Access Key ID
  secretKey String?  @db.Text // AWS Secret Access Key (Bedrock only; null for all other providers)
  models    String   @db.Text // JSON array: ["gpt-4.1","gpt-4.1-mini"]
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SheetIntegration {
  id        String   @id @default(cuid())
  name      String
  url       String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
