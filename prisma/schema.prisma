generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CandidateStage {
  SOURCED
  SHORTLISTED
  CONTACT_REQUESTED
  CONNECTED
  MESSAGED
  REPLIED
  INTERVIEW
  HIRED
  REJECTED
  ARCHIVED
}

// ─── Channel / Thread enums ────────────────────────────────────────────────────

enum ChannelType {
  LINKEDIN
  EMAIL
  WHATSAPP
}

enum ChannelStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// Generic thread lifecycle — channel-specific sub-states live in providerState JSON
enum ThreadStatus {
  PENDING // created, initial send not yet attempted
  ACTIVE // initial send done, follow-ups may be in flight
  REPLIED // candidate responded — terminal-good
  PAUSED // another thread on the same task got a reply
  ARCHIVED // timeout / exhausted / manually closed — terminal-bad
}

enum OutreachType {
  INVITE // LinkedIn connection request
  INMAIL // LinkedIn InMail (direct, no connection required)
  FIRST_DM // first DM after LinkedIn connection accepted
  EMAIL // email message (any position in sequence)
  FOLLOWUP // any follow-up message on any channel
  WHATSAPP // WhatsApp message
}

enum AccountType {
  LINKEDIN
  EMAIL
  WHATSAPP
}

enum DuplicateKind {
  LINKEDIN_URL
  RESUME_HASH
}

enum DuplicateStatus {
  PENDING
  RESOLVED_DELETED_A
  RESOLVED_DELETED_B
  RESOLVED_KEPT_BOTH
}

enum AccountStatus {
  ACTIVE
  BUSY
  COOLDOWN
  DISABLED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum TaskStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// Phase 8 / EC-13.1 — AI analysis sub-state, distinct from Task.status.
//   PENDING  - not yet run, OR running, OR skipped because no JD was configured.
//   OK       - analysis ran and produced a parsable scored result.
//   FAILED   - analysis attempted but errored after retries are exhausted
//              (provider down, malformed JSON, OOM, etc.). Surface to the UI
//              as "needs manual review" so candidates aren't stranded silently.
enum AnalysisStatus {
  PENDING
  OK
  FAILED
}

enum ThreadMessageStatus {
  SENT
  FAILED
}

model Account {
  id              String               @id @default(cuid())
  accountId       String               @unique // Unipile account_id
  name            String               @default("") // Friendly label
  type            AccountType          @default(LINKEDIN) // Which channel this account belongs to
  dsn             String? // Optional per-account override
  apiKey          String? // Optional per-account override
  status          AccountStatus        @default(ACTIVE)
  lastUsedAt      DateTime?
  requestCount    Int                  @default(0) // rolling counter
  dailyCount      Int                  @default(0) // daily usage counter
  dailyResetAt    DateTime? // when to reset dailyCount
  // P1 #27 / EC-13.6 — LinkedIn enforces a separate WEEKLY invite limit
  // (~100/week) on top of the daily cap. Tracking it here so the worker
  // can refuse to send invites once the weekly count reaches the limit
  // even when the daily counter still has room.
  weeklyCount     Int                  @default(0)
  weeklyResetAt   DateTime?
  // P1 #27 / EC-13.8 — fresh accounts must ramp gradually or LinkedIn /
  // email-providers ban them. While now < warmupUntil, the effective daily
  // cap is the warmup-ramp value (lib/channels/warmup.ts) instead of the
  // configured cap. Set on account creation; expires automatically.
  warmupUntil     DateTime?
  minuteCount     Int                  @default(0) // requests in current minute window
  minuteResetAt   DateTime? // when the current minute window expires
  cooldownUntil   DateTime? // null = not in cooldown
  // EC-9.6 — soft delete. Deleted accounts are excluded from selection but
  // referenced rows (channels, threads, messages) keep the FK so historical
  // attribution survives. A heal job warns admins when channels lose their
  // sender via this column.
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  tasks           Task[]
  channels        Channel[]
  threadsBound    ChannelThread[]
  threadMessages  ThreadMessage[]
  poolMemberships ChannelAccountPool[]

  @@index([deletedAt])
}

model Requisition {
  id             String          @id @default(cuid())
  title          String          @default("Untitled Role")
  department     String          @default("")
  recruiterName  String          @default("")
  startDate      DateTime?
  config         String?         @db.Text // JSON: JD, scoring rules, AI model, sheet target — the long-lived role config
  archived       Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  jobs           Job[]
  channels       Channel[]
  duplicatePairs DuplicatePair[]

  @@index([archived])
}

model Job {
  id             String    @id @default(cuid())
  requisitionId  String? // FK to the role this run belongs to (nullable for legacy rows)
  status         JobStatus @default(PENDING)
  totalTasks     Int
  processedCount Int       @default(0)
  successCount   Int       @default(0)
  failedCount    Int       @default(0)
  config         String?   @db.Text // JSON snapshot of the requisition config at run time
  createdAt      DateTime  @default(now())
  tasks          Task[]
  title          String    @default("Untitled Requisition")
  department     String    @default("")

  requisition Requisition? @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

// ─── Append-only policy ───────────────────────────────────────────────────────
// Task rows are append-only. Hard-deletion is forbidden except for GDPR erasure
// (separate codepath with audit log). The cleanup cron is permanently retired —
// see commit 2646e58. Soft-deleted rows are kept forever; they're cheap and
// preserve audit history. Never add a "purge soft-deleted" cron — write a
// one-off script with backups if that ever becomes necessary.
// The prisma client in lib/prisma.ts auto-filters deletedAt IS NULL on all
// findMany / findFirst / count operations. findUnique bypasses this filter
// intentionally (PK lookups are explicit). To see deleted tasks (admin only),
// pass `where: { deletedAt: { not: null } }` to override the default.
// ─────────────────────────────────────────────────────────────────────────────
model Task {
  id             String          @id @default(cuid())
  jobId          String
  url            String          @db.Text
  source         String          @default("linkedin_url") // "linkedin_url" | "resume" | "zip_import"
  sourceFileName String? // original filename for resume/zip imports
  sourceFileUrl  String? // S3 object key for the original PDF (resume/zip_import tasks)
  status         TaskStatus      @default(PENDING)
  result         String?         @db.Text // JSON string (raw Unipile profile data)
  analysisResult String?         @db.Text // JSON string (AI scoring output)
  // Phase 8 / EC-13.1 — explicit signal for the analysis sub-step. Distinct
  // from `status`, which tracks the whole task lifecycle (scrape + analyze).
  // PENDING = not yet run / running / skipped (no JD). OK = parsable scored
  // result. FAILED = retries exhausted; surface in a recruiter "needs review"
  // queue so candidates aren't stranded at SOURCED forever.
  analysisStatus AnalysisStatus  @default(PENDING)
  errorMessage   String?         @db.Text // failure reason
  retryCount     Int             @default(0)
  accountId      String? // assigned at processing time
  contentHash    String? // SHA-256 of resume text — dedup detection for resume/zip_import tasks
  stage          CandidateStage  @default(SOURCED)
  // manualStage wins over the auto-derived rollup for terminal recruiter decisions
  manualStage    CandidateStage?
  stageUpdatedAt DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  deletedReason  String?

  // Phase 6 / EC-10.1 — canonical candidate identity. Multiple Tasks may
  // share the same candidateProfileId across requisitions; this is the
  // join key for cross-task reply propagation. Nullable for backwards
  // compatibility (legacy Tasks have no link until backfilled).
  candidateProfileId String?

  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  account          Account?          @relation(fields: [accountId], references: [id])
  candidateProfile CandidateProfile? @relation(fields: [candidateProfileId], references: [id])
  outreachMessages OutreachMessage[]
  channelThreads   ChannelThread[]
  stageEvents      StageEvent[]
  notes            Note[]
  contact          CandidateContact?
  overrides        ScoreOverride[]
  duplicatesAsA    DuplicatePair[]   @relation("DuplicatePairA")
  duplicatesAsB    DuplicatePair[]   @relation("DuplicatePairB")

  @@index([jobId])
  @@index([accountId])
  @@index([stage])
  @@index([contentHash])
  @@index([deletedAt])
  @@index([candidateProfileId])
  // Index supporting the "needs review" recruiter query
  // (jobId + analysisStatus = FAILED).
  @@index([jobId, analysisStatus])
}

model DuplicatePair {
  id            String          @id @default(cuid())
  requisitionId String
  taskAId       String
  taskBId       String
  kind          DuplicateKind
  matchValue    String          @db.Text
  status        DuplicateStatus @default(PENDING)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime        @default(now())

  taskA       Task        @relation("DuplicatePairA", fields: [taskAId], references: [id], onDelete: Cascade)
  taskB       Task        @relation("DuplicatePairB", fields: [taskBId], references: [id], onDelete: Cascade)
  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@unique([taskAId, taskBId])
  @@index([requisitionId, status])
  @@index([taskAId])
  @@index([taskBId])
}

// OutreachMessage: kept for historical inbound reply tracking.
// campaignId is now a plain string with no FK — campaigns have been removed.
model OutreachMessage {
  id                String    @id @default(cuid())
  campaignId        String // historical — no longer a FK
  taskId            String
  channel           String
  status            String    @default("AWAITING_REVIEW")
  renderedSubject   String?
  renderedBody      String    @db.Text
  approvedAt        DateTime?
  scheduledFor      DateTime?
  sentAt            DateTime?
  providerMessageId String?
  providerChatId    String?
  direction         String    @default("OUT") // OUT | IN
  inboundBody       String?   @db.Text
  errorMessage      String?   @db.Text
  retryCount        Int       @default(0)
  createdAt         DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([taskId])
  @@index([providerChatId])
}

// ─── Multi-Channel Outreach System ────────────────────────────────────────────

// One Channel per (requisition, channel type) with JSON config for all rules.
// Replaces the per-channel Campaign rows conceptually; Campaign table is kept
// intact for backwards compatibility during migration.
model Channel {
  id               String        @id @default(cuid())
  requisitionId    String
  type             ChannelType
  name             String
  status           ChannelStatus @default(ACTIVE)
  // Validated JSON shape — see lib/channels/types.ts for the full schema
  config           Json
  sendingAccountId String?
  dailyCap         Int           @default(20)
  dailyInMailCap   Int           @default(5) // LinkedIn InMail credits are limited
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  requisition    Requisition          @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  sendingAccount Account?             @relation(fields: [sendingAccountId], references: [id])
  threads        ChannelThread[]
  accountPool    ChannelAccountPool[]

  @@index([requisitionId, type, status])
  @@index([sendingAccountId])
}

// P1 #14 / EC-9.2 — per-channel pool of allowed sending accounts. Fan-out
// picks from this pool by priority + round-robin (fewest threads first).
// Empty pool → fall back to channel.sendingAccount (legacy single-account
// binding). Doesn't activate until rows are inserted; safe additive change.
model ChannelAccountPool {
  id        String   @id @default(cuid())
  channelId String
  accountId String
  // Higher priority = picked first when multiple accounts have headroom.
  priority  Int      @default(0)
  // Reserved for future weighted-random selection. Not used yet but reserves
  // the column so the API doesn't break later.
  weight    Int      @default(1)
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([channelId, accountId])
  @@index([channelId, priority])
}

// One ChannelThread per (task, channel) — tracks the full per-candidate lifecycle
// for that channel. nextActionAt is the sole scheduling key used by the cron tick.
model ChannelThread {
  id                   String       @id @default(cuid())
  taskId               String
  channelId            String
  channelType          ChannelType // denormalized so cron can filter without joining
  status               ThreadStatus @default(PENDING)
  // Channel-specific sub-state (e.g. { phase: "INVITE_PENDING" | "CONNECTED" | "INMAIL_SENT" })
  providerState        Json?
  matchedRuleKey       String? // which inviteRule/emailRule/waRule fired
  nextActionAt         DateTime? // THE scheduling key — cron scans this
  inviteSentAt         DateTime? // set when LinkedIn invite is dispatched
  lastMessageAt        DateTime? // most recent outbound message timestamp
  followupsSent        Int          @default(0) // count of followups sent so far
  followupsTotal       Int          @default(0) // snapshot from config at thread creation
  providerChatId       String? // Unipile chat_id (LinkedIn DM / WA)
  providerThreadId     String? // email thread id
  archivedAt           DateTime?
  archivedReason       String?
  // EC-4.1 — write a UUID before the provider API call; clear it on commit.
  // If the worker crashes between API success and DB commit, a heal job can
  // detect (pendingSendKey IS NOT NULL AND pendingSendStartedAt < now-10min)
  // and recover. Nullable; not yet enforced as required.
  pendingSendKey       String?
  pendingSendStartedAt DateTime?
  // EC-9.3 — sticky per-thread account binding. Set at first send; immutable
  // thereafter. The conversation history (LinkedIn chat, WhatsApp number,
  // email Message-ID chain) lives on this account; switching mid-sequence
  // breaks reply tracking and leaks identity to recipients. The worker reads
  // this field if set; otherwise falls back to channel.sendingAccount.
  accountId            String?
  // P1 #41 / EC-13.13 — count of consecutive send failures. Incremented in
  // the catch path; reset to 0 on a successful commit. When >= threshold
  // (5 by default) the worker archives the thread with a structured reason
  // so a single broken candidate doesn't doom-loop and waste retries.
  consecutiveFailures  Int          @default(0)
  // P1 #39 / EC-13.7 — most recent inbound message timestamp (any channel,
  // but practically meaningful for WhatsApp). The 24h rolling free-form
  // messaging window: outside it Meta requires an approved Business
  // template, so the worker checks `now - lastInboundAt > 24h` before WA
  // sends and pauses-with-reason rather than failing/charging premium.
  lastInboundAt        DateTime?
  createdAt            DateTime     @default(now())

  task     Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  channel  Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  account  Account?        @relation(fields: [accountId], references: [id])
  messages ThreadMessage[]

  @@unique([taskId, channelId])
  @@index([status, nextActionAt]) // hot path: scheduler tick
  @@index([channelType, status]) // analytics + channel-level dashboards
  @@index([taskId]) // stage rollup lookup
}

// Outreach messages belonging to a ChannelThread (new system).
// The existing OutreachMessage model belongs to the Campaign (old system) and is
// kept untouched. These two models coexist during migration.
model ThreadMessage {
  id                String              @id @default(cuid())
  threadId          String
  type              OutreachType
  status            ThreadMessageStatus @default(SENT)
  renderedBody      String              @db.Text
  renderedSubject   String?
  sentAt            DateTime?
  providerMessageId String?
  providerChatId    String?
  errorMessage      String?             @db.Text
  // EC-9.3 — frozen-at-send forensic record of which account sent this
  // message. Set when the row is created; never updated. Survives even if
  // Channel.sendingAccountId changes later, so support / audit can answer
  // "which account sent this DM?"
  accountId         String?
  createdAt         DateTime            @default(now())

  thread  ChannelThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  account Account?      @relation(fields: [accountId], references: [id])

  // EC-6.1 — refuse duplicate rows when the provider returns the same
  // message ID twice (e.g., a retry that completed once successfully). Note:
  // Postgres treats NULL as distinct in unique indexes, so threads with
  // multiple NULL providerMessageId rows are unaffected (we couldn't
  // disambiguate them anyway).
  @@unique([threadId, providerMessageId], name: "ThreadMessage_threadId_providerMessageId_key")
  @@index([threadId, type])
  @@index([threadId, createdAt])
}

// Deduplication table for incoming Unipile (and future) webhooks.
// Insert-on-conflict-ignore at the top of every webhook handler.
model WebhookEvent {
  id          String    @id // provider's own event/message id
  provider    String // "unipile"
  eventType   String
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([provider, eventType, receivedAt])
}

// ──────────────────────────────────────────────────────────────────────────────

// P1 #34 / EC-12.5 — daily stage-distribution snapshot for incident
// detection. A scheduled job (app/api/cron/stage-snapshot) writes one row
// per (requisitionId, stage) per day. Anomaly detection compares the latest
// snapshot to recent ones — large day-over-day drops in any stage count
// (e.g., 100 SHORTLISTED yesterday, 12 today) indicate a destructive
// migration / cron / mass-update gone wrong, the kind of incident the
// 2026-04-29 mass-stage-reset would have produced.
model StageSnapshot {
  id            String         @id @default(cuid())
  capturedAt    DateTime       @default(now())
  requisitionId String?
  stage         CandidateStage
  count         Int

  @@unique([capturedAt, requisitionId, stage])
  @@index([requisitionId, capturedAt])
  @@index([capturedAt, stage])
}

model StageEvent {
  id        String          @id @default(cuid())
  taskId    String
  fromStage CandidateStage?
  toStage   CandidateStage
  actor     String          @default("USER") // USER | SYSTEM | RULE | WEBHOOK
  reason    String?
  createdAt DateTime        @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Note {
  id          String   @id @default(cuid())
  taskId      String
  authorEmail String   @default("")
  body        String   @db.Text
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model CandidateContact {
  id            String    @id @default(cuid())
  taskId        String    @unique
  email         String?
  linkedinEmail String?
  personalEmail String?
  workEmail     String?
  phone         String?
  salary        String? // Extracted from notes or profile
  source        String? // UNIPILE | WIZA | APOLLO | AIRSCALE | MANUAL
  confidence    Float?
  enrichedAt    DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ScoreOverride {
  id        String   @id @default(cuid())
  taskId    String
  ruleKey   String // e.g. "stability", "growth", "custom_abc123"
  paramKey  String // e.g. "promotionSameCompany"
  original  Int // AI's original score
  override  Int // HR's new score
  reason    String   @db.Text
  author    String   @default("")
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, paramKey])
  @@index([taskId])
}

model CandidateProfile {
  id                   String   @id @default(cuid())
  linkedinUrl          String // full LinkedIn URL (verbatim)
  // Phase 6 — canonical join key for cross-task identity. Computed from
  // linkedinUrl via lib/canonicalize-url.ts at insert/update time. Multiple
  // legacy rows may share the same canonical key (no unique constraint yet);
  // a follow-up dedup migration will collapse them and add @unique.
  canonicalLinkedinUrl String?
  name                 String   @default("")
  headline             String   @default("")
  location             String   @default("")
  rawProfile           String?  @db.Text // full Unipile JSON (nullable — cleared on free tier to save space)
  scrapedAt            DateTime @default(now())

  analyses AnalysisRecord[]
  tasks    Task[]

  @@index([linkedinUrl])
  @@index([canonicalLinkedinUrl])
  @@index([scrapedAt])
}

model AnalysisRecord {
  id            String @id @default(cuid())
  candidateId   String
  linkedinUrl   String // denormalized for fast queries
  candidateName String @default("")

  // Job context — WHY this analysis happened
  jobTitle       String
  jobDescription String @db.Text
  scoringConfig  String @db.Text // JSON: rules, custom rules, model, prompt

  // Analysis output with all reasoning
  analysisData String @db.Text // full AnalysisResult JSON

  // Denormalized for sorting/filtering/dashboards
  totalScore     Int
  maxScore       Int
  scorePercent   Float
  recommendation String // "Strong Fit" / "Moderate Fit" / "Not a Fit"

  analyzedAt DateTime @default(now())

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([linkedinUrl])
  @@index([analyzedAt])
  @@index([scorePercent])
  @@index([candidateId])
}

model JdTemplate {
  id                      String   @id @default(cuid())
  title                   String
  content                 String   @db.Text
  scoringRules            String   @db.Text // JSON: {"stability":true,"growth":false,...}
  customScoringRules      String   @db.Text // JSON: [{id,name,maxPoints,criteria,enabled}]
  builtInRuleDescriptions String   @default("{}") @db.Text // JSON: {"growth":"...","mba":"..."}
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model PromptTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationConfig {
  id                      String   @id @default(cuid())
  title                   String
  isDefault               Boolean  @default(false)
  promptRole              String?  @db.Text
  criticalInstructions    String?  @db.Text
  promptGuidelines        String?  @db.Text
  builtInRuleDescriptions String?  @db.Text // JSON: {"growth":"...","mba":"...",...}
  scoringRules            String?  @db.Text // JSON: {"stability":true,"growth":false,...}
  customScoringRules      String?  @db.Text // JSON: [{id,name,maxPoints,criteria,enabled}]
  ruleDefinitions         String?  @db.Text // JSON: Record<ruleKey, Partial<RuleDefinition>> — per-rule overrides for scoreParameters + logFormat
  promptEnvelope          String?  @db.Text // JSON: Partial<PromptEnvelope> — overrides for identity, section headers, JSON schema wrapper, footer
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model AppSettings {
  id                   String   @id @default("global")
  aiModel              String   @default("gpt-4.1")
  aiProviderId         String? // FK to AiProvider — the default provider
  sheetWebAppUrl       String   @default("")
  minScoreThreshold    Int      @default(0)
  promptRole           String?  @db.Text // Custom AI evaluator identity — null = default
  promptGuidelines     String?  @db.Text // Custom evaluation guidelines — null = default
  criticalInstructions String?  @db.Text // Custom behavioral rules — null = default
  updatedAt            DateTime @updatedAt
}

model AiProvider {
  id        String   @id @default(cuid())
  name      String // User-friendly label, e.g. "My Gemini"
  provider  String // "openai-compatible" | "anthropic" | "bedrock"
  baseUrl   String // API base URL — for Bedrock: AWS region (e.g. "us-east-1")
  apiKey    String // API key — for Bedrock: AWS Access Key ID
  secretKey String?  @db.Text // AWS Secret Access Key (Bedrock only; null for all other providers)
  models    String   @db.Text // JSON array: ["gpt-4.1","gpt-4.1-mini"]
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SheetIntegration {
  id        String   @id @default(cuid())
  name      String
  url       String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// GDPR erasure audit log — one row per bulk-erase action.
// Stores a snapshot of key identifiers before hard-deletion so there is a
// permanent record that the erasure happened (the data itself is gone).
model GdprErasure {
  id           String   @id @default(cuid())
  erasedAt     DateTime @default(now())
  erasedBy     String   @default("recruiter") // actor email/id — extend when auth is added
  taskCount    Int
  snapshotJson String   @db.Text // JSON: array of { taskId, url, name, stage }
}
